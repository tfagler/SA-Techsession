MYSQL_DATABASE=studyapp
MYSQL_USER=studyapp
MYSQL_PASSWORD=studyapp
MYSQL_ROOT_PASSWORD=rootpassword
DATABASE_URL=mysql+asyncmy://studyapp:studyapp@mysql:3306/studyapp
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
DOCS_DIR=/data/documents
CORS_ORIGINS=http://localhost:5173
LOCAL_LLM_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_ENABLED=false
LOCAL_LLM_CONTEXT_TOKENS=8192
LOCAL_LLM_PROMPT_BUDGET_TOKENS=6000
LOCAL_LLM_PROMPT_BUDGET_CHARS=20000
LOCAL_LLM_PROMPT_POLICY=truncate
HOSTED_LLM_URL=
HOSTED_LLM_MODEL=gpt-4o-mini
HOSTED_LLM_API_KEY=
LLM_MODE=auto
EMBED_DIM=128
USE_OLLAMA=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_TIMEOUT_CONNECT_SECONDS=10
OLLAMA_TIMEOUT_READ_SECONDS=180
OLLAMA_TIMEOUT_WRITE_SECONDS=30
OLLAMA_TIMEOUT_POOL_SECONDS=10
CRAWL_DEPTH=2
CRAWL_MAX_PAGES=200
CRAWL_MAX_LINKS_PER_PAGE=200
CRAWL_ALLOWED_DOMAINS=
CRAWL_INCLUDE_PDFS=true
CRAWL_INCLUDE_PATHS=
CRAWL_EXCLUDE_PATHS=
CRAWL_RESPECT_ROBOTS=true
CRAWL_CONCURRENCY=4
CRAWL_REQUEST_DELAY_MS=300
